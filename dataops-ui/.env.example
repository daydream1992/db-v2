# ─── DataOps 管理台 环境配置模板 ───────────────────────────────
# 复制此文件为 .env.local 并根据本地环境修改
# cp .env.example .env.local

# ─── 数据库路径 ────────────────────────────────────────────────
# DuckDB 数据库文件路径（Windows 示例：K:\\DB数据库_v2\\db\\profit_radar.duckdb）
NEXT_PUBLIC_DB_PATH=db/profit_radar.duckdb

# ─── 项目路径 ──────────────────────────────────────────────────
# 项目根目录
NEXT_PUBLIC_PROJECT_ROOT=.
# 备份目录
NEXT_PUBLIC_BACKUP_DIR=./archive

# ─── 服务端口 ──────────────────────────────────────────────────
# 日志流服务端口
NEXT_PUBLIC_LOG_STREAMER_PORT=3003

# ─── GitHub 仓库配置 ──────────────────────────────────────────
# 仓库地址（用于同步元数据）
NEXT_PUBLIC_GITHUB_REPO=https://github.com/daydream1992/db-v2
# 分支名
NEXT_PUBLIC_GITHUB_BRANCH=master
# Personal Access Token（仅在需要 push 同步时配置）
GITHUB_TOKEN=

# ─── 数据库连接（Prisma，如果使用） ────────────────────────────
DATABASE_URL=file:./dev.db
